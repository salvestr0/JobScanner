# Normalize all text files to LF in the repo (the app deploys on Linux/Render).
# This overrides per-machine core.autocrlf and stops CRLF<->LF churn on Windows.
* text=auto eol=lf

# Binary file types — never normalize.
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.zip  binary
*.db   binary
