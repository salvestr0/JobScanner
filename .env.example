# Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── Flask ────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# ── Database ─────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (Direct, port 5432)
# Local dev: leave as sqlite:///jobscanner_dev.db (no setup needed)
DATABASE_URL=sqlite:///jobscanner_dev.db

# ── Cron security ────────────────────────────────────────
# Protects the /api/cron/scan endpoint called by Railway cron.
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
CRON_SECRET=change-me-to-a-random-secret

# ── Stripe (billing) ─────────────────────────────────────
# Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Stripe dashboard → Products → your $8/month price → copy Price ID
STRIPE_PRICE_ID=price_...
# Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
# Webhook URL: https://your-domain.com/api/stripe/webhook
# Events to enable: customer.subscription.created, customer.subscription.updated,
#                   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (email) ───────────────────────────────────────
# resend.com → API Keys → Create API key
RESEND_API_KEY=re_...
# Must be from a verified domain in your Resend account.
# Format: "Display Name <email@yourdomain.com>"
RESEND_FROM=Job Scanner <noreply@yourdomain.com>

# ── Encryption (Gemini API key at-rest) ─────────────────
# Encrypts user Gemini API keys stored in the database.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production. If omitted, keys are stored as plaintext (not recommended).
ENCRYPTION_KEY=

# ── Adzuna (optional extra job source) ───────────────────
# Register free at developer.adzuna.com — free tier: 100 calls/day
# Leave blank to skip Adzuna (MCF + RemoteOK still run).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Fallback credentials ─────────────────────────────────
# Used as defaults when a user hasn't set their own credentials yet.
# Leave blank to require each user to configure their own via onboarding.
GEMINI_API_KEY=

# ── Error monitoring (Sentry) ────────────────────────────
# sentry.io → New Project → Flask → copy DSN
# Leave blank to disable (safe for local dev).
SENTRY_DSN=

# ── Rate limiter (Redis) ─────────────────────────────────
# Render: add a Redis service, copy the Internal Redis URL.
# Leave blank to fall back to in-memory limiting (resets on restart).
REDIS_URL=

# ── Admin dashboard ───────────────────────────────────────
# The email address that can access /admin. Only one admin supported.
# Leave blank to disable the admin dashboard entirely.
ADMIN_EMAIL=
